FROM registry.access.redhat.com/ubi9/python-311:latest

LABEL name="servicenow-mcp-server" \
      description="ServiceNow MCP server for LlamaStack agent integration" \
      io.k8s.display-name="ServiceNow MCP Server"

USER 0

RUN pip install --no-cache-dir \
    mcp-server-servicenow \
    mcp-proxy

USER 1001

EXPOSE 8080

ENV SERVICENOW_INSTANCE_URL="" \
    SERVICENOW_AUTH_TYPE="basic" \
    SERVICENOW_USERNAME="" \
    SERVICENOW_PASSWORD=""

ENTRYPOINT ["/opt/app-root/bin/mcp-proxy"]
CMD ["--host", "0.0.0.0", \
     "--port", "8080", \
     "--pass-environment", \
     "--", \
     "mcp-server-servicenow"]
